# ChefLeads environment variables
#
# Copy the server-side values into a local-only .dev.vars file (read by
# `wrangler pages dev`) and the VITE_* values into .env / .env.local
# (read by Vite). Neither .dev.vars nor .env is committed.
#
# Stub mode: when USE_STUBS=true, every external integration uses an in-memory
# mock adapter and NO real keys are required. The whole product runs end-to-end.
# Even without USE_STUBS, any service whose required keys are blank falls back to
# its mock automatically (see functions-lib/factory.ts).
USE_STUBS=true

# Placeholder-payments mode: keep the checkout mocked (click-through, instant
# unlock) while Supabase/Turnstile/Telegram/WhatsApp/PostHog all run for real.
# Use this to test the full lead -> link -> unlock flow before Grow is wired.
# Leave unset (or false) in a real payment deployment.
MOCK_PAYMENTS=false

# Public site origin, used for absolute canonical + hreflang URLs on SEO pages
# (build-time). The marketplace's canonical host is the apex ezfind.app — set
# this to it in the deploy env so canonicals point at the canonical host.
VITE_SITE_URL=https://ezfind.app

# Shared secret for the read-only operator view at /admin (it shows lead PII).
# Required in production to enable /admin; open automatically under USE_STUBS.
ADMIN_TOKEN=

# --- Supabase (server only) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Payments: Grow / Meshulam (server only) ---
GROW_API_KEY=
GROW_USER_ID=
GROW_PAGE_CODE=
GROW_WEBHOOK_SECRET=
# Where the provider redirects the chef after payment + where it posts the webhook.
PUBLIC_BASE_URL=http://localhost:8788

# --- Payments: Lemon Squeezy (server only, alternative provider) ---
# Set LEMONSQUEEZY_ENABLED=true to route checkout through Lemon Squeezy (takes
# precedence over Grow/Bit). Leave false/empty to disable. Enable "pay what you
# want" on the variant so per-lead prices are honored. See DEPLOYMENT.md §5b.
LEMONSQUEEZY_ENABLED=false
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# --- WhatsApp Cloud API (server only) ---
WA_CLOUD_TOKEN=
WA_PHONE_NUMBER_ID=
WA_MY_NUMBER=
WA_TEMPLATE_NAME=new_lead

# --- WhatsApp direct messages to end users (feature flags, server only) ---
# Client phone verification: require an OTP (delivered to the client's WhatsApp)
# before a lead is accepted. Needs the WA_* credentials above plus an approved
# AUTHENTICATION template. Flip to false any time to disable verification.
OTP_ENABLED=false
# Chef access links: automatically WhatsApp the paying chef their unlock link on
# payment confirmation, and enable self-service "send me my access link" on the
# lead page. Needs an approved UTILITY template with a URL button.
RECOVERY_ENABLED=false
# Template names as approved in Meta (defaults shown).
WA_OTP_TEMPLATE=otp_code
WA_ACCESS_TEMPLATE=lead_access

# --- Telegram Bot API (server only) ---
TG_TOKEN=
TG_CHAT_ID=

# --- Cloudflare Turnstile ---
# Server-side secret (used by Functions to verify):
TURNSTILE_SECRET=
# Client-side site key (exposed to the browser):
VITE_TURNSTILE_SITE_KEY=

# --- Analytics (client) ---
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# --- AdRoll (retargeting pixel, client) ---
# From AdRoll → Pixel / Settings. Both must be set for the pixel to load; it is
# consent-gated (fires only after the visitor accepts cookies).
VITE_ADROLL_ADV_ID=
VITE_ADROLL_PIXEL_ID=
