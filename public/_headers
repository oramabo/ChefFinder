/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://*.posthog.com https://s.adroll.com https://*.adroll.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://*.posthog.com https://challenges.cloudflare.com https://*.adroll.com https://*.adroll.io https://cloudflareinsights.com; frame-src https://challenges.cloudflare.com; base-uri 'self'; form-action 'self'

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/private-chef/*
  Cache-Control: public, max-age=3600

/kosher-private-chef/*
  Cache-Control: public, max-age=3600

# Hebrew canonical paths (/שף-פרטי/* and /שף-פרטי-כשר/*), percent-encoded.
/%D7%A9%D7%A3-%D7%A4%D7%A8%D7%98%D7%99/*
  Cache-Control: public, max-age=3600

/%D7%A9%D7%A3-%D7%A4%D7%A8%D7%98%D7%99-%D7%9B%D7%A9%D7%A8/*
  Cache-Control: public, max-age=3600
